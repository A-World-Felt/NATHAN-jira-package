# Configuration du serveur MCP JIRA NATHAN.
# Copier vers ~/.nathan/jira.env (config CENTRALE, lue quel que soit le repo courant).
# Le serveur MCP la charge au démarrage ; aucun repo n'a besoin de sa propre copie.

# --- Connexion JIRA (requis) ---
JIRA_BASE_URL=https://ton-site.atlassian.net
JIRA_EMAIL=you@example.com
JIRA_API_TOKEN=ton_jeton_api_atlassian

# Clés de projet à couvrir (séparées par des virgules) + projet des risques.
JIRA_PROJECT_KEYS=LIVS,DEV,GES,DC
RISK_PROJECT_KEY=RISK

# --- Profil de conventions (optionnel) ---
# Sans profil : le serveur est en PURE PLOMBERIE (params explicites, aucune convention).
# Avec profil : verbes convention-aware (labels de bloc, lint des résumés…).
# Nom de package publié OU chemin absolu vers le module du profil.
NATHAN_JIRA_PROFILE=@a-world-felt/nathan-jira-profile

# --- Snapshots préventifs (optionnel) ---
# Défaut neutre : ~/.nathan/snapshots. Pour réutiliser l'outillage `npm run restore`
# de gestion, pointer vers son dossier rapports/ :
# NATHAN_SNAPSHOT_DIR=C:/Users/<toi>/.../PMC/NATHAN-gestion/rapports
